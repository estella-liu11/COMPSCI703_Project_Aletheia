# ===========================================
# Aletheia Environment Variables Template
# ===========================================
# Copy this file to .env and fill in your actual values.
# IMPORTANT: Never commit .env to version control.

# ===========================================
# --- Vector DB Backend Selection ---
# ===========================================
#   pinecone → cloud serverless (default, fast, data leaves host)
#   chroma   → local persisted on disk (fully air-gapped, slower)
# Unlike LLM_BACKEND, this one is NOT switchable at runtime — your
# ingested embeddings live in whichever store you ingested them into.
VECTOR_DB_BACKEND=pinecone

# --- Pinecone Vector Database ---
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=aletheia-legal-db

# --- Chroma (local vector DB) ---
# Used when VECTOR_DB_BACKEND=chroma. Directory is created if missing.
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=aletheia

# ===========================================
# --- Chain-of-Verification toggle ---
# ===========================================
# true (default) → Chief Officer uses full CoVe (LLM generates per-claim
#                  verification questions, retrieves evidence per question).
# false          → falls back to simple "citation as query" re-retrieve.
#                  Useful for ablation runs in test_evaluation.py.
COVE_ENABLED=true

# ===========================================
# --- External Tools (live API enrichment) ---
# ===========================================
# When enabled, the pre-HITL graph's `enrich` node calls Frankfurter
# (api.frankfurter.app) to convert any USD/EUR/GBP/AUD/JPY/CNY amounts
# found in the contract into NZD at today's ECB-published rate, and
# injects that as evidence the Junior auditors can reason about.
# No API key required.
# Disable for fully air-gapped deployments (combine with
# LLM_BACKEND=ollama and VECTOR_DB_BACKEND=chroma for zero egress).
EXTERNAL_TOOLS_ENABLED=true

# --- Supabase (Auth + Postgres for user audit history) ---
# Project URL: Supabase Dashboard → Project Settings → General → Reference ID
# Publishable key: Project Settings → API Keys → Publishable key
#   (the "sb_publishable_*" one — safe for client-side use with RLS)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# ===========================================
# --- LLM Backend Selection ---
# ===========================================
# Aletheia supports two interchangeable backends; the Streamlit sidebar
# selector overrides this at runtime, but this value is the boot default.
#   ollama    → local Llama 3.2 via Ollama  (offline, free)
#   deepseek  → DeepSeek cloud API           (faster, needs API key)
LLM_BACKEND=ollama

# --- Ollama (Local LLM) ---
# Usually defaults to http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- DeepSeek API (OpenAI-compatible) ---
# Get a key at https://platform.deepseek.com/
# Models: deepseek-chat (V3, general) | deepseek-reasoner (R1, slower but stronger reasoning)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Optional: OpenAI (if using GPT models) ---
# OPENAI_API_KEY=your_openai_api_key_here
