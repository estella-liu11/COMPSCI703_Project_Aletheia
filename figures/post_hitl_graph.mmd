---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	route(route)
	extract(extract)
	verify(verify)
	chief(chief)
	escalate(escalate)
	__end__([<p>__end__</p>]):::last
	__start__ --> route;
	extract --> verify;
	route -.-> escalate;
	route -.-> extract;
	verify --> chief;
	chief --> __end__;
	escalate --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
